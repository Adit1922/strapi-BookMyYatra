{
  "kind": "collectionType",
  "collectionName": "mce_airline_lists",
  "info": {
    "singularName": "mce-airline-list",
    "pluralName": "mce-airline-lists",
    "displayName": "MCE-Airline-List"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "airline_name": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "airline_name"
    },
    "banner": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "mce_airline_detail": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::mce-airline-detail.mce-airline-detail",
      "inversedBy": "mce_airline_list"
    }
  }
}
