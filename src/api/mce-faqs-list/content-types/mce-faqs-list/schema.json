{
  "kind": "collectionType",
  "collectionName": "mce_faqs_lists",
  "info": {
    "singularName": "mce-faqs-list",
    "pluralName": "mce-faqs-lists",
    "displayName": "MCE-Faqs-List"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
